# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Comma-separated allowlist of frontend origins (CORS). localhost is always ok.
FRONTEND_URL=http://localhost:5173

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kmer_event
DB_USER=root
DB_PASSWORD=

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# REQUIRED. The server refuses to start without a strong JWT_SECRET (no fallback).
# Generate one with:  npm run generate:secret   (or: openssl rand -hex 48)
JWT_SECRET=
# Optional dedicated refresh-token key. If omitted it is derived from JWT_SECRET.
JWT_REFRESH_SECRET=
# Access-token lifetime (short). Refresh-token lifetime in days (long).
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
# Refresh-cookie attributes. Defaults: Secure+SameSite=None in production.
# For local HTTP stacks set COOKIE_SECURE=false and COOKIE_SAMESITE=lax.
# COOKIE_DOMAIN=
# COOKIE_SECURE=
# COOKIE_SAMESITE=

# ── Email (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
