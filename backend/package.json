{
  "name": "kmer-event-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --watch",
    "lint": "eslint .",
    "generate:secret": "node scripts/generate-secret.js",
    "migrate": "node scripts/init-db.js",
    "migrate:auth": "node scripts/migrate-auth-tables.js up",
    "migrate:auth:down": "node scripts/migrate-auth-tables.js down",
    "migrate:favorites": "node scripts/migrate-favorites.js up",
    "migrate:favorites:down": "node scripts/migrate-favorites.js down",
    "migrate:organizer-id": "node scripts/migrate-organizer-id.js up",
    "migrate:organizer-id:down": "node scripts/migrate-organizer-id.js down",
    "migrate:money-decimal": "node scripts/migrate-money-decimal.js up",
    "migrate:search-index": "node scripts/migrate-search-index.js up",
    "migrate:video-url": "node scripts/migrate-video-url.js up",
    "migrate:video-url:down": "node scripts/migrate-video-url.js down",
    "migrate:profile-picture": "node scripts/migrate-profile-picture.js up",
    "migrate:profile-picture:down": "node scripts/migrate-profile-picture.js down",
    "migrate:checkin": "node scripts/migrate-checkin.js up",
    "migrate:checkin:down": "node scripts/migrate-checkin.js down",
    "migrate:photo-urls": "node scripts/migrate-photo-urls.js up",
    "migrate:photo-urls:down": "node scripts/migrate-photo-urls.js down",
    "migrate:waitlist": "node scripts/migrate-waitlist.js up",
    "migrate:waitlist:down": "node scripts/migrate-waitlist.js down",
    "migrate:geo": "node scripts/migrate-geo.js up",
    "migrate:geo:down": "node scripts/migrate-geo.js down",
    "migrate:survey": "node scripts/migrate-survey.js up",
    "migrate:survey:down": "node scripts/migrate-survey.js down"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "nodemailer": "^6.9.4",
    "pdfkit": "^0.13.0",
    "qrcode": "^1.5.1",
    "sequelize": "^6.33.0",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.4"
  }
}
